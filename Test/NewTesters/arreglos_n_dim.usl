        // Multiplicación
        int[][] resultadoxx = new int[3][3];
        int mulrea = 0;
        int op12 = 0;
        int op14 = 0;
        int sumtemp = 0;
        for (int i = 0; i < matrizAleng; i++) {
            for (int j = 0; j < matrizBleng; j++) {
                for (int k = 0; k < matrizAleng; k++) {
                    op12 = matrizA[i][k];
                    op14 = matrizB[k][j];
                    mulrea = op12 * op14;
                    sumtemp += mulrea;
                    
                }
                resultadoxx[i][j] = sumtemp;
                op12 = 0;
                op14 = 0;
                mulrea = 0;
                sumtemp = 0;
            }
        }
