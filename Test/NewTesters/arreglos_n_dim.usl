    for (int i = 0; i < matrizAleng; i++) {
      if (i == 0) {
        int tupa = matrizA[0][0];
        int tupa2 = matrizA[0][1];
        int tupa3 = matrizA[0][2];
        System.out.println("[ " + tupa + ", " + tupa2 + ", " + tupa3 + " ]");
      }
      if (i == 1) {
        int tupa3 = matrizA[1][0];
        int tupa4 = matrizA[1][1];
        int tupa5 = matrizA[1][2];
        System.out.println("[ " + tupa3 + ", " + tupa4 + ", " + tupa5 + " ]");
      }
      if (i == 2) {
        int tupa6 = matrizA[2][0];
        int tupa7 = matrizA[2][1];
        int tupa8 = matrizA[2][2];
        System.out.println("[ " + tupa6 + ", " + tupa7 + ", " + tupa8 + " ]");
      }
    }
    
    // Determinante 3x3

    int aa = matrizA[0][0];
    int bb = matrizA[0][1];
    int cc = matrizA[0][2];
    
    // Menores 2x2
    int temps1 = matrizA[1][1];
    int temps2 = matrizA[2][2];
    int temps3 = matrizA[1][2];
    int temps4 = matrizA[2][1];
    int multi1 = temps1 * temps2;
    int multi2 = temps3 * temps4;
    int menor1 = multi1 - multi2;

    int temps5 = matrizA[1][0];
    int temps6 = matrizA[2][2];
    int temps7 = matrizA[1][2];
    int temps8 = matrizA[2][0];
    int multi3 = temps5 * temps6;
    int multi4 = temps7 * temps8;
    int menor2 = multi3 - multi4;

    int temps9 = matrizA[1][0];
    int temps10 = matrizA[2][1];
    int temps11 = matrizA[1][1];
    int temps12 = matrizA[2][0];
    int multi5 = temps9 * temps10;
    int multi6 = temps11 * temps12;
    int menor3 = multi5 - multi6;
    
    int multi7 = aa * menor1;
    int multi8 = bb * menor2;
    int multi9 = cc * menor3;
    int complex3 = (multi7 - multi8 + multi9);

    System.out.println("Determinante 3x3 de matriz A: " + complex3);

    
    // Otra matriz 3x3
    int[][] matriz3x3_especial = {
        {2, -1, 3},
        {1, 0, 1},
        {1, 2, -1}
    };
    
    System.out.println("\nMatriz especial 3x3:");
    for (int i = 0; i < matrizAleng; i++) {
      if (i == 0) {
        int tupa62 = matriz3x3_especial[0][0];
        int tupa63 = matriz3x3_especial[0][1];
        int tupa64 = matriz3x3_especial[0][2];
        System.out.println("[ " + tupa62 + ", " + tupa63 + ", " + tupa64 + " ]");
      }
      if (i == 1) {
        int tupa65 = matriz3x3_especial[1][0];
        int tupa66 = matriz3x3_especial[1][1];
        int tupa67 = matriz3x3_especial[1][2];
        System.out.println("[ " + tupa65 + ", " + tupa66 + ", " + tupa67 + " ]");
      }
      if (i == 2) {
        int tupa68 = matriz3x3_especial[2][0];
        int tupa69 = matriz3x3_especial[2][1];
        int tupa70 = matriz3x3_especial[2][2];
        System.out.println("[ " + tupa68 + ", " + tupa69 + ", " + tupa70 + " ]");
      }
    }
    
    int aaa = matriz3x3_especial[0][0];
    int bbb = matriz3x3_especial[0][1];
    int ccc = matriz3x3_especial[0][2];
    
    // Menores 2x2
    int temps13 = matriz3x3_especial[1][1];
    int temps14 = matriz3x3_especial[2][2];
    int temps15 = matriz3x3_especial[1][2];
    int temps16 = matriz3x3_especial[2][1];
    int multi77 = temps13 * temps14;
    int multi88 = temps15 * temps16;
    int menor4 = multi77 - multi88;

    int temps17 = matriz3x3_especial[1][0];
    int temps18 = matriz3x3_especial[2][2];
    int temps19 = matriz3x3_especial[1][2];
    int temps20 = matriz3x3_especial[2][0];
    int multi99 = temps17 * temps18;
    int multi10 = temps19 * temps20;
    int menor5 = multi99 - multi10;

    int temps21 = matriz3x3_especial[1][0];
    int temps22 = matriz3x3_especial[2][1];
    int temps23 = matriz3x3_especial[1][1];
    int temps24 = matriz3x3_especial[2][0];
    int multi11 = temps21 * temps22;
    int multi12 = temps23 * temps24;
    int menor6 = multi11 - multi12;
    
    int multi13 = aaa * menor4;
    int multi14 = bbb * menor5;
    int multi15 = ccc * menor6;
    int complex4 = (multi13 - multi14 + multi15);

    System.out.println("Determinante 3x3: " + complex4);
    
    System.out.println("\n=== ANALISIS DE DATOS ACADEMICOS COMPLETADO ===");
}

