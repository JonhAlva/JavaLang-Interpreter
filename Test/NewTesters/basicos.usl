void main(String[] args) {
    System.out.println("=== SISTEMA DE CALCULO CIENTIFICO ===");
    
    // Declaración de variables
    int numeroEntero = 42;
    float numeroFlotante = 3.14f;
    double numeroDoble = 2.718281828;
    char caracter = "A";
    boolean esVerdadero = true;
    String cadenaTexto = "Resultado";
    
    // Declaración y uso de constantes
    double PI = 3.14159265359;
    int CONSTANTE_MAXIMA = 100;
    String MENSAJE_SISTEMA = "Calculadora Científica v1.0";
    CONSTANTE_MAXIMA = 10; // ERROR
    
    System.out.println(MENSAJE_SISTEMA);
    System.out.println("Constante PI: " + PI);
    System.out.println("Constante máxima: " + CONSTANTE_MAXIMA);
    
    // Asignación de variables
    numeroEntero = 100;
    numeroFlotante = 5.67f;
    caracter = "Z";
    esVerdadero = false;
    cadenaTexto = "Nuevo resultado";
    
    System.out.println("\n--- VALORES ASIGNADOS ---");
    System.out.println("Entero: " + numeroEntero);
    System.out.println("Flotante: " + numeroFlotante);
    System.out.println("Carácter: " + caracter);
    System.out.println("Booleano: " + esVerdadero);
    System.out.println("Cadena: " + cadenaTexto);
    
    // Operaciones aritméticas
    int a = 25;
    int b = 7;
    
    System.out.println("\n--- OPERACIONES ARITMETICAS ---");
    System.out.println("a = " + a + ", b = " + b);
    int Opxx = a + b;
    System.out.println("Suma (a + b): " + Opxx);
    Opxx = a - b;
    System.out.println("Resta (a - b): " + Opxx);
    Opxx = a * b;
    System.out.println("Multiplicación (a * b): " + Opxx);
    float Opx = a / b;
    System.out.println("División (a / b): " + Opx);
    int Opxz = a % b;
    System.out.println("Módulo (a % b): " + Opxz);
    
    // Operaciones relacionales
    System.out.println("\n--- OPERACIONES RELACIONALES ---");
    boolean pols = a > b;
    System.out.println("a > b: " + pols);
    pols = a < b;
    System.out.println("a < b: " + pols);
    pols = a >= b;
    System.out.println("a >= b: " + pols);
    pols = a <= b;
    System.out.println("a <= b: " + pols);
    pols = a == b;
    System.out.println("a == b: " + pols);
    pols = a != b;
    System.out.println("a != b: " + pols);
    
    // Operaciones lógicas
    boolean condicion1 = true;
    boolean condicion2 = false;
    
    System.out.println("\n--- OPERACIONES LOGICAS ---");
    boolean lops = condicion1;
    System.out.println("condicion1 = " + lops);
    lops = condicion2;
    System.out.println("condicion2 = " + lops);
    lops = condicion1 && condicion2;
    System.out.println("condicion1 && condicion2: " + lops);
    lops = condicion1 || condicion2;
    System.out.println("condicion1 || condicion2: " + lops);
    lops = !condicion1;
    System.out.println("!condicion1: " + lops);
    lops = !condicion2;
    System.out.println("!condicion2: " + lops);
    
    // Operadores AND, OR y XOR
    int x = 12;  // 1100 en binario
    int y = 10;  // 1010 en binario
    
    System.out.println("\n--- OPERADORES DE BITS ---");
    System.out.println("x = " + x + " (binario: 1100)");
    System.out.println("y = " + y + " (binario: 1010)");
    x &= y;
    System.out.println("x & y (AND): " + x);
    x = 12;
    x |= y;
    System.out.println("x | y (OR): " + x);
    x = 12;
    x ^= y;
    System.out.println("x ^ y (XOR): " + x);
    
    // Operadores de desplazamiento izquierda y derecha
    int valorDesplazamiento = 16;  // 10000 en binario
    
    System.out.println("\n--- DESPLAZAMIENTO DE BITS ---");
    System.out.println("valor = " + valorDesplazamiento);
    valorDesplazamiento <<= 2;
    System.out.println("valor << 2: " + valorDesplazamiento);
    valorDesplazamiento = 16;
    valorDesplazamiento >>= 2;
    System.out.println("valor >> 2: " + valorDesplazamiento);
    
    // Secuencias de escape
    System.out.println("\n--- SECUENCIAS DE ESCAPE ---");
    System.out.println("Comillas dobles: 'Hola mundo'");
    System.out.println("Barra invertida: \");
    System.out.println("Nueva línea:\nTexto en línea nueva");
    System.out.println("Retorno de carro:Texto con retorno");
    System.out.println("Tabulación:     Texto con tab");
    
    // Salto de línea compuesto (\r\n)
    System.out.println("Línea antes del salto compuesto\nLínea después del salto compuesto");
    
    // Manejo de null
    String textoNulo = "null";
    System.out.println("\n--- MANEJO DE NULL ---");
    
    if (textoNulo == "null") {
        System.out.println("La variable textoNulo es null");
        textoNulo = "Valor asignado después de verificar null";
    }
    
    System.out.println("textoNulo ahora: " + textoNulo);
    
    String otroTextoNulo = "null";
    if (otroTextoNulo == "null") {
        String resultado = "Es Null";
        System.out.println("Resultado condicional: " + resultado);
    }
    
    // Widening Casting completo (char -> int -> float -> double)
    System.out.println("\n--- WIDENING CASTING AUTOMATICO ---");
    char letraInicial = "M";
    int codigoAscii = letraInicial;        // char -> int
    float codigoFloat = codigoAscii;       // int -> float  
    double codigoDouble = codigoFloat;     // float -> double
    
    System.out.println("Casting automático progresivo:");
    System.out.println("char '" + letraInicial + "' -> int " + codigoAscii);
    System.out.println("int " + codigoAscii + " -> float " + codigoFloat);
    System.out.println("float " + codigoFloat + " -> double " + codigoDouble);
    
    // Narrowing Casting completo (double -> float -> int -> char)
    System.out.println("\n--- NARROWING CASTING MANUAL ---");
    double valorGrande = 75.89;
    float valorMedio = (float) valorGrande;    // double -> float
    int valorEntero = (int) valorMedio;        // float -> int
    char caracterFinal = (char) valorEntero;   // int -> char
    
    System.out.println("Casting manual regresivo:");
    System.out.println("double " + valorGrande + " -> float " + valorMedio);
    System.out.println("float " + valorMedio + " -> int " + valorEntero);
    System.out.println("int " + valorEntero + " -> char '" + caracterFinal + "'");
    
    int variableComentada = 50; // Comentario al final de línea
    
    /* Este es un comentario
      multilínea para indicar
      el final del programa
      también prueba el comentario */
    
    // Cálculo final útil
    int maso = valorEntero + codigoAscii;
    double resultadoFinal = (PI * maso) / 2.0;
    System.out.println("\n--- CALCULO FINAL (SIMAULACION CÁLCULO REAL ) ---");
    System.out.println("Resultado científico: " + resultadoFinal);

    // --- FIGURAS GEOMETRICAS ---
    // Círculo
    double radioCirculoCm = maso / 10.0;
    double areaCirculoCm2 = PI * radioCirculoCm * radioCirculoCm;
    double perimetroCirculoCm = 2 * PI * radioCirculoCm;

    // Rectángulo
    int baseRectCm = a;
    int alturaRectCm = b;
    int areaRectCm2 = baseRectCm * alturaRectCm;
    int sumaxx = baseRectCm + alturaRectCm;
    int perimetroRectCm = 2 * sumaxx;

    System.out.println("\n--- FIGURAS GEOMETRICAS ---");
    System.out.println("Circulo -> radio=" + radioCirculoCm + " cm, area=" + areaCirculoCm2 + " cm^2, perimetro=" + perimetroCirculoCm + " cm");
    System.out.println("Rectangulo -> base=" + baseRectCm + " cm, altura=" + alturaRectCm + " cm, area=" + areaRectCm2 + " cm^2, perimetro=" + perimetroRectCm + " cm");
    
    System.out.println("\n=== FIN DEL SISTEMA ===");
}


